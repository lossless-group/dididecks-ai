---
import BaseLayout from '../layouts/BaseLayout.astro';

const northStars = [
  {
    tag: 'NS-1',
    title: 'Two-sided system — private native ↔ white-label publish',
    body: 'A native desktop workspace where a managing partner develops decks with Claude in private, paired with a white-label publish target that lives in the client\'s brand. The boundary between the two sides is itself the product.',
  },
  {
    tag: 'NS-2',
    title: 'A player so good you present live, from the deck',
    body: 'The author of the deck uses DidiDecks to make it. The author of the deck also uses DidiDecks to play it — in front of the LP, the GP, the board. Keynote/PPT/PDF export is a handoff artifact, not the presentation runtime.',
  },
];

const principles = [
  { n: '01', title: 'Auth vs. publish, balanced', body: 'Confidential by default for sensitive materials, easy-to-publish for the rest, with the boundary visible and controllable.' },
  { n: '02', title: 'AI design agents that wow-ify prior art', body: 'Take ugly prior decks (or a Google Doc outline) to shareable polish on a 6-day turnaround. AI not optional. Timeline not optional. Polish bar not optional.' },
  { n: '03', title: 'Non-destructive iteration', body: 'Tweak, embellish, try variants, reorder — but never destroy. Optionality is a deliverable, not a side-effect.' },
  { n: '04', title: 'MVP-playable deck, always', body: 'At any given moment, a deck must be ready to present. On-the-fly opportunities don\'t wait.' },
  { n: '05', title: 'Continuous iterate, fork, personalize', body: 'Improve and personalize toward a specific meeting on short notice — without ever breaking the always-playable MVP.' },
  { n: '06', title: 'Passable PDF export', body: 'Looks-like-it-came-from-Keynote is the export bar. No "obviously generated by a web tool" tells.' },
  { n: '07', title: 'Periodic urgent content integration', body: 'New market research, fresh news, yesterday\'s call transcript — folded in near-urgently and reflowed without manual rebuild.' },
];

const siblings = [
  {
    href: 'https://github.com/lossless-group/dididecks-ai/blob/development/context-v/specs/Dididecks-AI-Slide-Decks-as-Code.md',
    tag: 'Spec — Parent',
    title: 'Slide Decks as Code',
    body: 'Decks are repositories, slides are components, variants are first-class, AI is the primary author. The narrative spec everything else hangs off of.',
  },
  {
    href: 'https://github.com/lossless-group/dididecks-ai/blob/development/context-v/specs/Dididecks-AI-DD-Ready-Citation-and-Source-Access.md',
    tag: 'Spec — Sibling',
    title: 'DD-Ready Citation & Source Access',
    body: 'Every claim, chart, and KPI is backable. A receiver clicks a citation, pulls the source, and continues their DD without contacting the sender.',
  },
  {
    href: 'https://github.com/lossless-group/dididecks-ai/blob/development/context-v/specs/Dididecks-AI-Visual-and-Diagram-Component-Library.md',
    tag: 'Spec — Sibling',
    title: 'Visual & Diagram Component Library',
    body: 'Reusable, AI-composable visual primitives — 2x2s, value chains, layered stacks, comp grids, mental-model frames — so each new deck reaches "wow" without redrawing.',
  },
  {
    href: 'https://github.com/lossless-group/dididecks-ai/blob/development/context-v/explorations/Dididecks-AI-Business-Model.md',
    tag: 'Exploration',
    title: 'Business Model',
    body: 'Build in public, copyleft where we can, copyright where it matters. Hosted + Forward Deployed humans as the real growth engine. Option-space, not commitment.',
  },
];
---
<BaseLayout>
  <header class="hero">
    <div class="container">
      <p class="eyebrow">DidiDecks-AI · The Lossless Group</p>
      <h1>Decks for Due Diligence, not for vibes.</h1>
      <p class="lede">
        A code-first slide-deck operating system for receiving-side Due-Diligence-grade content.
        Not a "better Gamma." The category single-deck tools don't address: ingest → wow-ify →
        variant → publish → export → re-integrate, on a six-day clock, with citations that survive.
      </p>
      <div class="hero-meta">
        <span><strong>Status:</strong> Early architecture</span>
        <span><strong>Branches:</strong> development → main → master</span>
        <span><strong>Parent:</strong> <a href="https://github.com/lossless-group/ai-labs">ai-labs</a></span>
        <span><strong>Repo:</strong> <a href="https://github.com/lossless-group/dididecks-ai">lossless-group/dididecks-ai</a></span>
      </div>
    </div>
  </header>

  <section>
    <div class="container">
      <p class="eyebrow">The bar</p>
      <h2>The Due Diligence Bar is the bar.</h2>
      <p class="lede" style="max-width: 60ch;">
        The codename DidiDecks is a contraction of <em>Due Diligence</em>. That isn't decoration —
        it is the entire reason this product exists. A pretty deck that can't be backed up by source
        material doesn't pass DD. A claim without a citable source is a vibe, not a substantiation.
        DD eats vibes for breakfast.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <p class="eyebrow">North Stars</p>
      <h2>Two hard targets.</h2>
      <div class="split" style="margin-top: 2rem;">
        {northStars.map((ns) => (
          <article class="card">
            <span class="tag">{ns.tag}</span>
            <h3>{ns.title}</h3>
            <p>{ns.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <p class="eyebrow">Design principles</p>
      <h2>Seven recurring needs.</h2>
      <p class="lede" style="max-width: 60ch; margin-bottom: 2rem;">
        Each one is a hard requirement. Together they define the gap single-deck tools don't fill.
      </p>
      <div class="grid">
        {principles.map((p) => (
          <article class="card">
            <span class="tag">{p.n}</span>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <p class="eyebrow">System map</p>
      <h2>The loop.</h2>
      <p class="lede" style="max-width: 60ch; margin-bottom: 2rem;">
        Positioned against the systems gap, not against any single-deck tool. End-to-end for repeat,
        high-stakes, time-pressured client work.
      </p>
      <div class="system-map">
<pre>{`ingest  →  wow-ify  →  variant  →  publish (with auth)  →  export (Keynote-grade)
                                       ↑                          │
                                       └──── re-integrate ────────┘
                                             fresh inputs`}</pre>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <p class="eyebrow">Specs & explorations</p>
      <h2>What's written down so far.</h2>
      <div class="grid" style="margin-top: 2rem;">
        {siblings.map((s) => (
          <a class="card" href={s.href}>
            <span class="tag">{s.tag}</span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>
        Built in public by <a href="https://lossless.group">The Lossless Group</a> ·
        <a href="https://github.com/lossless-group/dididecks-ai">github</a> ·
        Part of the <a href="https://github.com/lossless-group/ai-labs">ai-labs</a> pseudomonorepo
      </p>
      <p class="kicker">OSS posture under exploration · License terms TBD</p>
    </div>
  </footer>
</BaseLayout>

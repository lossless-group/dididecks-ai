---
/**
 * SlideRankPill — floating overlay for in-scroll-deck ranking.
 *
 * Consumer drops <SlideRankPill deckSlug variantSlug /> once into a scroll-deck
 * page. The component watches sibling `<section data-slot data-variant>` tags,
 * tracks which one is centered in the viewport via IntersectionObserver, and
 * provides a small bottom-right pill that shows the active slot's title, its
 * current rank, and the 5 rank-status buttons.
 *
 * Server-side: this component reads the slot registry via
 * `__dididecksShellOptions` and embeds `{slot: title}` as a JSON blob the
 * inline script consumes. The same path the TOC route uses.
 *
 * Production note: the pill renders in static builds, but its API calls
 * (GET/POST /api/slide-rank) fail-soft against a non-existent prod endpoint —
 * so it becomes effectively read-only without throwing.
 */
import type { SlotRef } from "../types/index.js";
import { loadSlotsRegistry } from "../registry-loader.js";

interface Props {
  deckSlug: string;
  variantSlug: string;
  /**
   * Which surface this pill is rating — `"scroll"` when mounted inside a
   * Scroll-UI page; `"play"` when composed by `<DeckOverlay--Play-UI>`. Drives
   * both the hydration read (`audit.ranks[k][surface].status`) and the POST
   * write. Transitional: omitting the prop logs a one-time console warning
   * and defaults to `"scroll"`; the default is removed in a later release.
   */
  surface?: "scroll" | "play";
  /**
   * Corner placement. Default `bottom-right` matches the Scroll-UI behavior
   * shipped in Phase A+. Pass `top-right` when composing inside
   * `DeckOverlay--Play-UI` to avoid stacking on top of `DeckChrome`, which
   * occupies the bottom-right capsule slot in Play-UI.
   */
  position?: "bottom-right" | "top-right";
}

const rawProps = Astro.props as Props;
const surfaceProvided = rawProps.surface !== undefined;
const {
  deckSlug,
  variantSlug,
  surface = "scroll",
  position = "bottom-right",
} = rawProps;

const opts = globalThis.__dididecksShellOptions;
let slots: SlotRef[] = [];
if (opts) {
  try {
    const mod = await loadSlotsRegistry(opts.absolute.slotsRegistry, opts.absolute.scrollPagesRoot);
    slots = mod?.SLOTS?.[variantSlug] ?? [];
  } catch {
    // registry not loadable — pill will degrade to slot-number only
  }
}

const titleBySlot: Record<string, string> = Object.fromEntries(
  slots.map((s) => [s.slot, s.title]),
);
---
<div
  class:list={["dididecks-slide-rank-pill", `dididecks-slide-rank-pill--${position}`]}
  data-slide-rank-pill
  data-position={position}
  data-surface={surface}
  data-surface-provided={surfaceProvided ? "true" : "false"}
  data-deck-slug={deckSlug}
  data-variant-slug={variantSlug}
  data-titles={JSON.stringify(titleBySlot)}
  hidden
>
  <div class="dididecks-slide-rank-pill__head">
    <span class="dididecks-slide-rank-pill__slot" data-slot-num>—</span>
    <span class="dididecks-slide-rank-pill__title" data-slot-title>No slot in view</span>
  </div>
  <div class="dididecks-slide-rank-pill__pills" role="group" aria-label="Slot rank">
    <button type="button" class="dididecks-slide-rank-pill__pill" data-status="urgent-redo" title="Urgent redo">U</button>
    <button type="button" class="dididecks-slide-rank-pill__pill" data-status="non-urgent-could-be-better" title="Could be better">C</button>
    <button type="button" class="dididecks-slide-rank-pill__pill" data-status="passable" title="Passable">P</button>
    <button type="button" class="dididecks-slide-rank-pill__pill" data-status="perfect" title="Perfect">★</button>
    <button type="button" class="dididecks-slide-rank-pill__pill" data-status="pending" title="Clear rank">–</button>
  </div>
</div>

<style>
  .dididecks-slide-rank-pill {
    position: fixed;
    right: 16px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 280px;
    padding: 10px 12px;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 10px;
    background: var(--color-surface, var(--color-background, #ffffff));
    color: var(--color-text, #0a0a0a);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
    font: 12px/1.4 -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    opacity: 0.35;
    transition: opacity 0.15s ease;
  }
  .dididecks-slide-rank-pill--bottom-right { bottom: 16px; }
  .dididecks-slide-rank-pill--top-right    { top: 16px; }

  .dididecks-slide-rank-pill:hover,
  .dididecks-slide-rank-pill:focus-within {
    opacity: 1;
  }
  .dididecks-slide-rank-pill[hidden] {
    display: none;
  }
  .dididecks-slide-rank-pill__head {
    display: flex;
    align-items: baseline;
    gap: 6px;
    overflow: hidden;
  }
  .dididecks-slide-rank-pill__slot {
    color: var(--color-accent-1, var(--color-text-muted, #737373));
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    flex: 0 0 auto;
  }
  .dididecks-slide-rank-pill__title {
    flex: 1 1 auto;
    color: var(--color-text, #0a0a0a);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .dididecks-slide-rank-pill__pills {
    display: flex;
    gap: 4px;
  }
  .dididecks-slide-rank-pill__pill {
    flex: 1;
    padding: 6px 0;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 999px;
    background: transparent;
    color: var(--color-text, #0a0a0a);
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .dididecks-slide-rank-pill__pill:hover {
    background: var(--color-background, #ffffff);
  }
  .dididecks-slide-rank-pill__pill.is-active[data-status="urgent-redo"] {
    background: #ff5e57; color: #fff; border-color: transparent;
  }
  .dididecks-slide-rank-pill__pill.is-active[data-status="non-urgent-could-be-better"] {
    background: #ffb84a; color: #1a1a1a; border-color: transparent;
  }
  .dididecks-slide-rank-pill__pill.is-active[data-status="passable"] {
    background: #66c0f4; color: #0b1a26; border-color: transparent;
  }
  .dididecks-slide-rank-pill__pill.is-active[data-status="perfect"] {
    background: #4ade80; color: #06210c; border-color: transparent;
  }
  .dididecks-slide-rank-pill__pill.is-active[data-status="pending"] {
    background: #6b7280; color: #fff; border-color: transparent;
  }
</style>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-slide-rank-pill]");
    if (!root) return;

    const deckSlug = root.dataset.deckSlug;
    const variantSlug = root.dataset.variantSlug;
    const surface = root.dataset.surface === "play" ? "play" : "scroll";
    const surfaceProvided = root.dataset.surfaceProvided === "true";
    if (!surfaceProvided) {
      console.warn(
        "[@dididecks/shell] <SlideRankPill> rendered without a 'surface' prop. " +
          "Defaulting to 'scroll' for backcompat. Pass surface=\"scroll\" or surface=\"play\" explicitly.",
      );
    }
    let titles = {};
    try { titles = JSON.parse(root.dataset.titles || "{}"); } catch {}

    const slotEl = root.querySelector("[data-slot-num]");
    const titleEl = root.querySelector("[data-slot-title]");
    const pillButtons = Array.from(root.querySelectorAll("[data-status]"));

    /** Local cache of {key: status} where key = deck/variant/slot */
    const ranks = new Map();
    function rankKey(slot) { return `${deckSlug}/${variantSlug}/${slot}`; }

    let activeSlot = null;

    function renderActive() {
      if (!activeSlot) {
        root.setAttribute("hidden", "");
        return;
      }
      root.removeAttribute("hidden");
      slotEl.textContent = activeSlot;
      titleEl.textContent = titles[activeSlot] || `Slot ${activeSlot}`;
      const current = ranks.get(rankKey(activeSlot)) || "pending";
      pillButtons.forEach((b) => {
        if (b.dataset.status === current) b.classList.add("is-active");
        else b.classList.remove("is-active");
      });
    }

    // Hydrate ranks cache from /api/slide-rank (dev only — fails-soft in prod)
    fetch("/api/slide-rank", { method: "GET" })
      .then((r) => (r.ok ? r.json() : null))
      .then((audit) => {
        if (!audit || !audit.ranks) return;
        // Hydrate from the surface this pill rates against. Schema v2 stores
        // up to two surfaces per row; we read only ours so a play-side rating
        // doesn't accidentally show as the scroll-side state (or vice versa).
        for (const [k, v] of Object.entries(audit.ranks)) {
          if (!k.startsWith(`${deckSlug}/${variantSlug}/`) || !v) continue;
          const surfaceEntry = v[surface];
          if (surfaceEntry && surfaceEntry.status) ranks.set(k, surfaceEntry.status);
        }
        renderActive();
      })
      .catch(() => {});

    // Track which section is most centered in viewport
    const sections = Array.from(
      document.querySelectorAll(`section[data-slot][data-variant="${variantSlug}"]`),
    );
    if (sections.length === 0) return;

    const visibility = new Map(); // section -> intersectionRatio
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) visibility.set(entry.target, entry.intersectionRatio);
          else visibility.delete(entry.target);
        }
        // pick highest ratio
        let bestSection = null;
        let bestRatio = 0;
        for (const [sec, ratio] of visibility) {
          if (ratio > bestRatio) { bestRatio = ratio; bestSection = sec; }
        }
        if (bestSection) {
          activeSlot = bestSection.getAttribute("data-slot");
          renderActive();
        }
      },
      { threshold: [0, 0.25, 0.5, 0.75, 1] },
    );
    sections.forEach((s) => io.observe(s));

    // Click handler — optimistic update + POST
    pillButtons.forEach((btn) => {
      btn.addEventListener("click", async () => {
        if (!activeSlot) return;
        const status = btn.dataset.status;
        const key = rankKey(activeSlot);
        const prev = ranks.get(key) || "pending";
        if (status === "pending") ranks.delete(key);
        else ranks.set(key, status);
        renderActive();
        try {
          const res = await fetch("/api/slide-rank", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ deckSlug, variantSlug, slot: activeSlot, status, surface }),
          });
          if (!res.ok) throw new Error(`POST /api/slide-rank failed: ${res.status}`);
        } catch (err) {
          // revert optimistic update
          if (prev === "pending") ranks.delete(key);
          else ranks.set(key, prev);
          renderActive();
          console.warn("@dididecks/shell: rank update failed", err);
        }
      });
    });
  })();
</script>

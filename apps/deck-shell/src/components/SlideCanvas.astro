---
/**
 * SlideCanvas — fixed-aspect 16:9 wrapper for a single play slide.
 *
 * Lifted from client-sites/calmstorm-decks/src/components/slides/SlideCanvas.astro
 * (the proven pattern for slides that need to render at a fixed 1920×1080
 * design size yet letterbox cleanly into any container — viewport, print
 * page, embed). The Phase A++ plan flagged this as the eventual lift into
 * `@dididecks/shell`; doing it client-side first to ship the chroma PDF
 * tonight, will re-home into the shell in Phase A++.3 tomorrow.
 *
 * Authoring model: slide content lives in a 1920×1080 conceptual stage.
 * The canvas scales the stage to fit whatever parent it's inside, preserving
 * the aspect ratio. ResizeObserver re-applies on every layout change.
 */
export interface Props {
  designWidth?: number;
  designHeight?: number;
  title?: string;
  background?: string;
}

const {
  designWidth = 1920,
  designHeight = 1080,
  title,
  background,
} = Astro.props;
---

<div
  class="slide-canvas"
  data-slide-canvas
  data-design-width={designWidth}
  data-design-height={designHeight}
  aria-label={title}
  style={background ? `--canvas-bg: ${background};` : undefined}
>
  <div
    class="slide-canvas__stage"
    style={`width: ${designWidth}px; height: ${designHeight}px;`}
  >
    <slot />
  </div>
</div>

<style>
  .slide-canvas {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--canvas-bg, #ffffff);
    container-type: size;
  }
  .slide-canvas__stage {
    position: absolute;
    top: 0;
    left: 0;
    transform-origin: top left;
    /* CSS-only fallback scale via container queries. Works without JS.
       The JS below refines for sub-pixel accuracy + resize handling. */
    transform: scale(min(
      calc(100cqi / 1px / 1920),
      calc(100cqb / 1px / 1080)
    ));
  }
  /* Print uses the same CSS scale as screen — container-query units (cqi/cqb)
     resolve against the slide-canvas's own size, so the stage scales to
     whatever the print page gives it. No special print overrides needed. */
</style>

<script>
  function scaleSlideCanvas(el: HTMLElement) {
    const stage = el.querySelector<HTMLElement>(".slide-canvas__stage");
    if (!stage) return;
    const designW = Number(el.dataset.designWidth || 1920);
    const designH = Number(el.dataset.designHeight || 1080);
    const rect = el.getBoundingClientRect();
    if (rect.width === 0 || rect.height === 0) return;
    const scale = Math.min(rect.width / designW, rect.height / designH);
    stage.style.transform = `scale(${scale})`;
  }

  function init(el: HTMLElement) {
    if ((el as unknown as { __slideCanvasInit?: boolean }).__slideCanvasInit) return;
    (el as unknown as { __slideCanvasInit?: boolean }).__slideCanvasInit = true;
    const ro = new ResizeObserver(() => scaleSlideCanvas(el));
    ro.observe(el);
    scaleSlideCanvas(el);
  }

  for (const el of document.querySelectorAll<HTMLElement>("[data-slide-canvas]")) {
    init(el);
  }
  new MutationObserver((mutations) => {
    for (const m of mutations) {
      for (const node of m.addedNodes) {
        if (node instanceof HTMLElement) {
          if (node.matches?.("[data-slide-canvas]")) init(node);
          for (const inner of node.querySelectorAll?.("[data-slide-canvas]") ?? []) {
            init(inner as HTMLElement);
          }
        }
      }
    }
  }).observe(document.body, { childList: true, subtree: true });
</script>

---
/**
 * DeckStatsPanel — quick-stats tile grid for the consumer's landing page.
 *
 * Calmstorm + chroma each had their own AssetsDataPanel rendering a 4-tile
 * row (variants / slide files / people / companies) above the deck-level
 * matrix on /. Both lifted into the shell as this component so consumer
 * sites don't reinvent the count math or the tile chrome.
 *
 * Props: deckSlug (required) — used to look up the variant list + the
 * deck-scoped slot registry.
 *
 * Data sources:
 *   - DECKS registry             → variant count + labels
 *   - SLOTS registry             → registered slot count per variant
 *   - perSlideFileExists()       → static-ported / authored slide files
 *   - /data/(any)/(team|portfolio)/*.md     → people (role_class present)
 *   - /data/(any)/portfolio/*.md            → companies (no role_class)
 *   - path extraction on company .md files → distinct backer-firm count
 *   - colocated headshot files               → headshot count
 *
 * All counts at build time. No runtime fetching. Heavy lifting is the
 * import.meta.glob calls — same pattern as the data-assets routes so the
 * counts always match the audit pages.
 */
import type { Deck, SlotRef } from "../types/index.js";
import {
  loadDecksRegistry,
  loadSlotsRegistry,
  perSlideFileExists,
} from "../registry-loader.js";

interface Props {
  deckSlug: string;
}
const { deckSlug } = Astro.props as Props;

const opts = globalThis.__dididecksShellOptions;
if (!opts) {
  throw new Error("@dididecks/shell <DeckStatsPanel>: options not resolved. Did astro:config:done run?");
}

const { DECKS } = await loadDecksRegistry(opts.absolute.decksRegistry);
const deck = (DECKS as Deck[]).find((d) => d.slug === deckSlug);
const variants = deck?.variants ?? [];

const slotsMod = await loadSlotsRegistry(opts.absolute.slotsRegistry, opts.absolute.scrollPagesRoot);
const slotsByVariant: Record<string, SlotRef[]> = slotsMod?.SLOTS ?? {};

// Registered slots = union of slot entries across all variants (build-time).
let registeredSlots = 0;
let authoredSlotFiles = 0;
for (const variant of variants) {
  const slots = slotsByVariant[variant.slug] ?? [];
  registeredSlots += slots.length;
  for (const s of slots) {
    const exists = await perSlideFileExists(
      opts.absolute.slidesComponentsRoot,
      variant.slug,
      s.slot,
      s.slug,
    );
    if (exists) authoredSlotFiles += 1;
  }
}
// Every per-slide file is by definition a static-play port.
const staticPorted = authoredSlotFiles;

// People + companies counts via the same globs the audit pages use.
const peopleMdGlob = import.meta.glob<string>(
  "/data/**/{team,portfolio}/*.md",
  { eager: true, query: "?raw", import: "default" },
);
const companyMdGlob = import.meta.glob<string>(
  "/data/**/portfolio/*.md",
  { eager: true, query: "?raw", import: "default" },
);
const headshotGlob = import.meta.glob<string>(
  "/data/**/{team,portfolio}/*.{png,jpg,jpeg,webp,avif,svg}",
  { eager: true, query: "?url", import: "default" },
);

// Avoiding multi-line regex literals here — esbuild's TS pre-parse has
// sometimes flagged them as unterminated when in expression-adjacent
// positions inside .astro frontmatter. String-method extraction works.
function frontmatterBlock(raw: string): string {
  const start = raw.indexOf("---\n");
  if (start !== 0) return "";
  const end = raw.indexOf("\n---", 4);
  if (end < 0) return "";
  return raw.slice(4, end);
}
function getFrontmatterField(raw: string, key: string): string | null {
  const fm = frontmatterBlock(raw);
  if (!fm) return null;
  const prefix = `${key}:`;
  for (const line of fm.split("\n")) {
    if (!line.startsWith(prefix)) continue;
    let v = line.slice(prefix.length).trim();
    if (!v) return null;
    if (v.startsWith('"') && v.endsWith('"')) v = v.slice(1, -1);
    else if (v.startsWith("'") && v.endsWith("'")) v = v.slice(1, -1);
    return v === "null" ? null : v;
  }
  return null;
}
function hasRoleClass(raw: string): boolean {
  const v = getFrontmatterField(raw, "role_class");
  return !!v && v !== "null";
}
function dirname(p: string): string {
  const i = p.lastIndexOf("/");
  return i < 0 ? p : p.slice(0, i);
}
function parseHeadshotFilename(raw: string): string | null {
  const v = getFrontmatterField(raw, "headshot");
  if (!v) return null;
  return v.startsWith("./") ? v.slice(2) : v;
}
function firmSlugFromPath(p: string): string {
  // Match /data/firms/{firm}/portfolio/ or /data/investors/{firm}/portfolio/
  const parts = p.split("/").filter(Boolean);
  if (parts[0] === "data" && (parts[1] === "firms" || parts[1] === "investors") && parts[3] === "portfolio") {
    return parts[2];
  }
  if (parts[0] === "data" && parts[2] === "portfolio") return parts[1];
  return "(unknown)";
}

const peopleEntries = Object.entries(peopleMdGlob).filter(([, raw]) => hasRoleClass(raw as unknown as string));
const peopleCount = peopleEntries.length;
let headshotCount = 0;
for (const [mdPath, raw] of peopleEntries) {
  const filename = parseHeadshotFilename(raw as unknown as string);
  if (!filename) continue;
  if (headshotGlob[`${dirname(mdPath)}/${filename}`]) headshotCount += 1;
}

const companyPaths = Object.keys(companyMdGlob);
// Each .md is one company-listing. Same company can appear under multiple
// firms (chroma's portfolio overlap). Count both: total listings + distinct.
const companyListingsCount = companyPaths.length;
function stripMdExt(s: string): string {
  return s.endsWith(".md") ? s.slice(0, -3) : s;
}
const distinctCompanySlugs = new Set(
  companyPaths.map((p) => {
    const file = p.split("/").pop();
    return file ? stripMdExt(file) : "";
  }),
).size;
const firmCount = new Set(companyPaths.map(firmSlugFromPath)).size;

const tiles = [
  {
    href: `/scroll/${deckSlug}/`,
    num: variants.length,
    label: "Design Variants",
    meta: variants.length > 0 ? variants.map((v) => v.label).join(" · ") : "",
    cta: "Go to scroll UI",
  },
  {
    href: `/toc/${deckSlug}/`,
    num: authoredSlotFiles,
    label: "Slide Files",
    meta: `${staticPorted} ported to static play · ${registeredSlots} registered`,
    cta: "See TOC matrix",
  },
  {
    href: "/data-assets/people",
    num: peopleCount,
    label: "People",
    meta: `${headshotCount} with headshot`,
    cta: "See people",
  },
  {
    href: "/data-assets/companies",
    num: companyListingsCount,
    label: "Companies",
    meta:
      firmCount > 1
        ? `${distinctCompanySlugs} distinct · across ${firmCount} firms`
        : `${distinctCompanySlugs} distinct`,
    cta: "See companies",
  },
];
---

<section class="ddd-stats" aria-label="Deck assets & data">
  <header class="ddd-stats__head">
    <p class="ddd-stats__eyebrow">Assets &amp; Data</p>
    <p class="ddd-stats__lede">
      Reviewer audit. What we have for the deck's variants, slots, and the
      people / companies referenced across them — to spot inconsistencies
      before publishing.
    </p>
  </header>

  <div class="ddd-stats__grid">
    {tiles.map((t) => (
      <a href={t.href} class="ddd-stats__tile">
        <div class="ddd-stats__tile-head">
          <span class="ddd-stats__tile-num">{t.num}</span>
          <span class="ddd-stats__tile-label">{t.label}</span>
        </div>
        {t.meta && <p class="ddd-stats__tile-meta">{t.meta}</p>}
        <span class="ddd-stats__tile-cta">{t.cta} <span aria-hidden="true">→</span></span>
      </a>
    ))}
  </div>
</section>

<style>
  /* Theming tokens — inherit from --ddd-stats-* (component-specific) and
     fall back to consumer color-system tokens when present, else neutral
     defaults. Consumers override at any wrapping element. */
  .ddd-stats {
    --stats-bg:         var(--ddd-stats-bg,         var(--color-background, transparent));
    --stats-surface:    var(--ddd-stats-surface,    var(--color-surface,    color-mix(in srgb, currentColor 5%, transparent)));
    --stats-surface-hover: var(--ddd-stats-surface-hover, color-mix(in srgb, currentColor 9%, transparent));
    --stats-border:     var(--ddd-stats-border,     var(--color-border,     color-mix(in srgb, currentColor 12%, transparent)));
    --stats-border-hover: var(--ddd-stats-border-hover, color-mix(in srgb, currentColor 35%, transparent));
    --stats-fg:         var(--ddd-stats-fg,         var(--color-text,       currentColor));
    --stats-fg-muted:   var(--ddd-stats-fg-muted,   var(--color-text-muted, color-mix(in srgb, currentColor 60%, transparent)));
    --stats-radius:     var(--ddd-stats-radius,     var(--radius, 4px));
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--stats-border);
    color: var(--stats-fg);
  }
  .ddd-stats__head { margin-bottom: 1.25rem; max-width: 42rem; }
  .ddd-stats__eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--stats-fg-muted);
    margin: 0 0 0.5rem 0;
  }
  .ddd-stats__lede {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--stats-fg-muted);
    margin: 0;
  }
  .ddd-stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  @media (max-width: 1100px) { .ddd-stats__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px)  { .ddd-stats__grid { grid-template-columns: 1fr; } }

  .ddd-stats__tile {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border: 1px solid var(--stats-border);
    background: var(--stats-surface);
    border-radius: var(--stats-radius);
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .ddd-stats__tile:hover {
    border-color: var(--stats-border-hover);
    background: var(--stats-surface-hover);
  }
  .ddd-stats__tile-head {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  .ddd-stats__tile-num {
    font-size: 2.5rem;
    font-weight: 200;
    line-height: 1;
    color: var(--stats-fg);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }
  .ddd-stats__tile-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--stats-fg-muted);
  }
  .ddd-stats__tile-meta {
    font-size: 0.78rem;
    color: var(--stats-fg-muted);
    margin: 0;
  }
  .ddd-stats__tile-cta {
    margin-top: 0.4rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--stats-fg);
    letter-spacing: 0.02em;
  }
</style>

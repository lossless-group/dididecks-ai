---
/**
 * ScrollIcon-A — surface-shaped frame.
 * Portrait rectangle (the long scroll page) with three content lines and a
 * downward chevron. Paired with PlayIcon-A. Stroke-only; currentColor.
 */
interface Props {
  size?: number | string;
  title?: string;
}
const { size = "1em", title = "Scroll review" } = Astro.props as Props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  role="img"
  aria-label={title}
>
  <title>{title}</title>
  <rect x="6" y="2.5" width="12" height="19" rx="2" />
  <line x1="9" y1="7" x2="15" y2="7" />
  <line x1="9" y1="10" x2="15" y2="10" />
  <line x1="9" y1="13" x2="13" y2="13" />
  <polyline points="9.5 17 12 19.5 14.5 17" />
</svg>

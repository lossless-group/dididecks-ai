---
/**
 * DeckMatrix — deck-level dual-surface review matrix as an embeddable component.
 *
 * Drop into any consumer page that wants a deck rollup. Renders the full
 * variants × slots matrix with dual-surface (Scroll + Play) ratings per cell,
 * per-variant shippability rollups in column headers, and a per-row drift
 * indicator. Reads from the same audits registry the /api/slide-rank endpoint
 * writes to, so it reflects current state without an extra fetch.
 *
 * Consumers:
 *   - apps/deck-shell/src/routes/toc-deck.astro  (canonical /toc/[deck] route)
 *   - client-sites/<client>/src/pages/index.astro  (landing dashboard)
 *   - any splash / share-tier page that wants a deck-progress surface
 *
 * Props:
 *   - deckSlug (required) — which deck to render
 *   - focusVariant (optional) — variant slug to ring/highlight (e.g. when the
 *     consumer also has a column-specific link selected). The /toc/[deck]
 *     route reads ?variant=X from the URL and passes it through.
 *   - title (optional) — heading rendered above the matrix; pass null to omit
 *   - lede (optional) — short description below the heading; pass null to omit
 *   - showNav (optional, default false) — render the shell's DididecksNav above
 *     the matrix. The /toc/[deck] route uses this; landing dashboards usually
 *     have their own chrome and pass false (the default).
 *
 * Plan of record:
 *   context-v/plans/Redesign-TOC-as-Deck-Level-Dual-Surface-Review-Matrix.md
 *   (Phase 5.5)
 */
import type { Deck, SlotRef, Status, Surface } from "../types/index.js";
import { buildRankKey } from "../types/index.js";
import {
  loadDecksRegistry,
  loadSlotsRegistry,
  loadAuditRegistry,
  perSlideFileExists,
} from "../registry-loader.js";
import DididecksNav from "./DididecksNav.astro";
import ScrollIcon from "./icons/ScrollIcon.astro";
import PlayIcon from "./icons/PlayIcon.astro";

interface Props {
  deckSlug: string;
  focusVariant?: string | null;
  title?: string | null;
  lede?: string | null;
  showNav?: boolean;
}

const {
  deckSlug,
  focusVariant: focusVariantProp = null,
  title: titleProp,
  lede: ledeProp,
  showNav = false,
} = Astro.props as Props;

const opts = globalThis.__dididecksShellOptions;
if (!opts) {
  throw new Error("@dididecks/shell <DeckMatrix>: options not resolved. Did astro:config:done run?");
}

const { DECKS } = await loadDecksRegistry(opts.absolute.decksRegistry);
const deck = (DECKS as Deck[]).find((d) => d.slug === deckSlug);

const slotsMod = await loadSlotsRegistry(opts.absolute.slotsRegistry);
const slotsByVariant: Record<string, SlotRef[]> = slotsMod?.SLOTS ?? {};

const audit = await loadAuditRegistry(opts.absolute.audits);

type Rated = Exclude<Status, "pending">;
type CellSurface =
  | { kind: "rated"; status: Rated }
  | { kind: "pending" }
  | { kind: "missing-slot" }
  | { kind: "missing-file" };

interface Cell {
  scroll: CellSurface;
  play: CellSurface;
  scrollHref: string | null;
  playHref: string | null;
  drift: boolean;
  blocker: boolean;
}

function compareSlot(a: string, b: string): number {
  const ra = /^(\d+)(.*)$/.exec(a);
  const rb = /^(\d+)(.*)$/.exec(b);
  const na = ra ? parseInt(ra[1], 10) : Number.MAX_SAFE_INTEGER;
  const nb = rb ? parseInt(rb[1], 10) : Number.MAX_SAFE_INTEGER;
  if (na !== nb) return na - nb;
  return (ra?.[2] ?? "").localeCompare(rb?.[2] ?? "");
}

const allVariants = deck?.variants ?? [];

// Visible-variant filter. Max 3 columns at a time keeps the header readable.
// Default: the last 3 variants in registry order (typically the most-refined
// iterations; the baseline lives at index 0). URL-param override:
// ?variants=slug1,slug2,slug3 — invalid slugs are dropped; if the param is
// present but no valid slugs match, fall back to the default.
const MAX_VISIBLE_VARIANTS = 3;
const variantsParam = Astro.url.searchParams.get("variants");
const requestedSlugs: string[] = variantsParam
  ? variantsParam.split(",").map((s) => s.trim()).filter(Boolean)
  : [];
const validRequested = requestedSlugs.filter((s) =>
  allVariants.some((v) => v.slug === s),
);
const visibleSlugs: string[] = validRequested.length > 0
  ? validRequested.slice(0, MAX_VISIBLE_VARIANTS)
  : allVariants.slice(-MAX_VISIBLE_VARIANTS).map((v) => v.slug);
const visibleSet = new Set(visibleSlugs);

const variants = allVariants.filter((v) => visibleSet.has(v.slug));

// Compute each chip's "what set would clicking this produce" — drives the
// chip-strip hrefs so the toggle is pure-server navigation (no JS state).
function chipHrefFor(slug: string): string {
  const isSelected = visibleSet.has(slug);
  let nextSlugs: string[];
  if (isSelected) {
    // Toggle off — but don't allow the empty state. If clicking would leave
    // zero visible, drop the request entirely (revert to default).
    nextSlugs = visibleSlugs.filter((s) => s !== slug);
  } else if (visibleSlugs.length < MAX_VISIBLE_VARIANTS) {
    nextSlugs = [...visibleSlugs, slug];
  } else {
    // 3 selected, adding a 4th — FIFO drop oldest.
    nextSlugs = [...visibleSlugs.slice(1), slug];
  }
  const params = new URLSearchParams(Astro.url.search);
  if (nextSlugs.length === 0) {
    params.delete("variants");
  } else {
    params.set("variants", nextSlugs.join(","));
  }
  const qs = params.toString();
  return `${Astro.url.pathname}${qs ? `?${qs}` : ""}`;
}

const slotSet = new Set<string>();
const titleBySlot: Record<string, string> = {};
const slugBySlotByVariant: Record<string, Record<string, string>> = {};
for (const variant of variants) {
  const variantSlots = slotsByVariant[variant.slug] ?? [];
  slugBySlotByVariant[variant.slug] = {};
  for (const s of variantSlots) {
    slotSet.add(s.slot);
    if (!titleBySlot[s.slot]) titleBySlot[s.slot] = s.title;
    slugBySlotByVariant[variant.slug][s.slot] = s.slug;
  }
}
const orderedSlots = Array.from(slotSet).sort(compareSlot);

const PASSABLE_OR_BETTER: ReadonlySet<Rated> = new Set(["passable", "perfect"]);

function readSurface(
  variantSlug: string,
  slot: string,
  surface: Surface,
  hasFile: boolean,
  variantHasSlot: boolean,
): CellSurface {
  if (!variantHasSlot) return { kind: "missing-slot" };
  if (surface === "play" && !hasFile) return { kind: "missing-file" };
  const key = buildRankKey(deckSlug, variantSlug, slot);
  const entry = audit.ranks[key]?.[surface];
  if (entry && entry.status) return { kind: "rated", status: entry.status };
  return { kind: "pending" };
}

function isBlocker(cell: CellSurface): boolean {
  if (cell.kind === "missing-slot") return false;
  if (cell.kind === "rated") return !PASSABLE_OR_BETTER.has(cell.status);
  return true;
}

type Rollup = {
  scroll: Record<Rated | "pending" | "na", number>;
  play: Record<Rated | "pending" | "missing-file" | "na", number>;
  totalRated: number;
  ready: boolean;
};

const emptyScroll = (): Rollup["scroll"] => ({
  "urgent-redo": 0,
  "non-urgent-could-be-better": 0,
  passable: 0,
  perfect: 0,
  pending: 0,
  na: 0,
});
const emptyPlay = (): Rollup["play"] => ({
  "urgent-redo": 0,
  "non-urgent-could-be-better": 0,
  passable: 0,
  perfect: 0,
  pending: 0,
  "missing-file": 0,
  na: 0,
});

const rollups: Record<string, Rollup> = {};
for (const v of variants) {
  // A variant is structurally eligible for Ready only if it has at least one
  // slot in its registry. Zero-slot variants (e.g. chroma's enhanced-v1
  // before any SLOTS entries land) are vacuously "no blockers found", which
  // is technically true but reads as a false positive in the UI. Initialize
  // ready=false for empty variants so the badge reflects reality.
  const variantSlotCount = (slotsByVariant[v.slug] ?? []).length;
  rollups[v.slug] = {
    scroll: emptyScroll(),
    play: emptyPlay(),
    totalRated: 0,
    ready: variantSlotCount > 0,
  };
}

interface Row {
  slot: string;
  title: string;
  cells: Record<string, Cell>;
  drift: boolean;
}

const rows: Row[] = await Promise.all(
  orderedSlots.map(async (slot) => {
    const cells: Record<string, Cell> = {};
    let rowDrift = false;
    for (const variant of variants) {
      const variantHasSlot = slugBySlotByVariant[variant.slug]?.[slot] !== undefined;
      const slug = variantHasSlot ? slugBySlotByVariant[variant.slug][slot] : "";
      const hasFile = variantHasSlot
        ? await perSlideFileExists(opts.absolute.slidesComponentsRoot, variant.slug, slot, slug)
        : false;
      const scroll = readSurface(variant.slug, slot, "scroll", hasFile, variantHasSlot);
      const play = readSurface(variant.slug, slot, "play", hasFile, variantHasSlot);

      const drift =
        scroll.kind === "rated" && play.kind === "rated" && scroll.status !== play.status;
      if (drift) rowDrift = true;

      const cell: Cell = {
        scroll,
        play,
        scrollHref: variantHasSlot ? `/scroll/${deckSlug}/${variant.slug}/#slot-${slot}` : null,
        playHref: variantHasSlot && hasFile ? `/play/${deckSlug}/${variant.slug}/${slot}/` : null,
        drift,
        blocker: isBlocker(scroll) || isBlocker(play),
      };
      cells[variant.slug] = cell;

      const r = rollups[variant.slug];
      if (scroll.kind === "missing-slot") r.scroll.na += 1;
      else if (scroll.kind === "rated") {
        r.scroll[scroll.status] += 1;
        r.totalRated += 1;
      } else r.scroll.pending += 1;
      if (play.kind === "missing-slot") r.play.na += 1;
      else if (play.kind === "missing-file") r.play["missing-file"] += 1;
      else if (play.kind === "rated") {
        r.play[play.status] += 1;
        r.totalRated += 1;
      } else r.play.pending += 1;
      if (cell.blocker && variantHasSlot) r.ready = false;
    }
    return { slot, title: titleBySlot[slot] ?? slot, cells, drift: rowDrift };
  }),
);

const focusVariant =
  focusVariantProp && variants.some((v) => v.slug === focusVariantProp) ? focusVariantProp : null;

const STATUS_LABEL: Record<Rated | "pending", string> = {
  "urgent-redo": "U",
  "non-urgent-could-be-better": "C",
  passable: "P",
  perfect: "★",
  pending: "—",
};

const resolvedTitle = titleProp === undefined ? deck?.title ?? deckSlug : titleProp;
const resolvedLede =
  ledeProp === undefined
    ? `${variants.length} ${variants.length === 1 ? "variant" : "variants"} · ${orderedSlots.length} ${orderedSlots.length === 1 ? "slot" : "slots"}. Each cell pairs a Scroll-UI review (left) and a Play-UI review (right). Click an icon to open that surface for that slot. Drift (≠) means Scroll and Play rated the same slot differently — the port may have lost fidelity.`
    : ledeProp;
---

{showNav && <DididecksNav />}

<section class="deck-matrix">
  {(resolvedTitle || resolvedLede) && (
    <header class="deck-matrix__head">
      <div class="deck-matrix__crumb">@dididecks/shell · TOC matrix</div>
      {resolvedTitle && <h2 class="deck-matrix__title">{resolvedTitle}</h2>}
      {resolvedLede && <p class="deck-matrix__lede">{resolvedLede}</p>}

      {allVariants.length > 1 && (
        <div class="deck-matrix__variant-filter" role="group" aria-label="Filter visible variants">
          <span class="deck-matrix__variant-filter-label">
            Variants <span class="deck-matrix__variant-filter-count">({visibleSlugs.length} of {allVariants.length})</span>
          </span>
          <ul class="deck-matrix__variant-filter-chips">
            {allVariants.map((v) => {
              const selected = visibleSet.has(v.slug);
              return (
                <li>
                  <a
                    href={chipHrefFor(v.slug)}
                    class="deck-matrix__variant-chip"
                    data-selected={selected ? "true" : "false"}
                    aria-pressed={selected ? "true" : "false"}
                    title={
                      selected
                        ? `Hide ${v.label}`
                        : visibleSlugs.length >= MAX_VISIBLE_VARIANTS
                        ? `Show ${v.label} — will drop the oldest selected to keep ${MAX_VISIBLE_VARIANTS} max`
                        : `Show ${v.label}`
                    }
                  >
                    {v.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      )}
    </header>
  )}

  {variants.length === 0 || orderedSlots.length === 0 ? (
    <div class="deck-matrix__empty">
      <p>No variants or slots registered for this deck yet.</p>
    </div>
  ) : (
    <div class="deck-matrix__scroll">
      <table class="deck-matrix__table">
        <thead>
          <tr>
            <th class="deck-matrix__slot-col" scope="col">Slot</th>
            <th class="deck-matrix__title-col" scope="col">Title</th>
            {variants.map((v) => {
              const r = rollups[v.slug];
              const isFocused = v.slug === focusVariant;
              const scrollHref = `/scroll/${deckSlug}/${v.slug}/`;
              // /play/[deck]/[variant]/ is a redirect to the first playable
              // slot. If the variant has zero playable slots (every cell is
              // missing-file or n/a), the link would 404 — gate it.
              const playCount =
                r.play.perfect +
                r.play.passable +
                r.play["non-urgent-could-be-better"] +
                r.play["urgent-redo"] +
                r.play.pending;
              const playHref = playCount > 0 ? `/play/${deckSlug}/${v.slug}/` : null;
              return (
                <th
                  class:list={["deck-matrix__variant-col", { "is-focused": isFocused }]}
                  scope="col"
                >
                  <div class="deck-matrix__variant-head">
                    <div class="deck-matrix__variant-label">
                      <a
                        class="deck-matrix__variant-name"
                        href={`/toc/${deckSlug}/${v.slug}/`}
                        title={`Open ${v.label} landing — per-variant slot list with ranks`}
                      >{v.label}</a>
                    </div>

                    <a
                      class="deck-matrix__surface-row deck-matrix__surface-row--link"
                      href={scrollHref}
                      title={`Open scroll deck for ${v.label}`}
                    >
                      <span class="deck-matrix__surface-icon"><ScrollIcon size="14px" /></span>
                      <span class="deck-matrix__rollup-pill" aria-label="Scroll-UI rollup">
                        <span class="deck-matrix__rollup-seg" data-status="perfect"                     data-zero={r.scroll.perfect === 0 ? "true" : "false"}><span class="g">★</span>{r.scroll.perfect}</span>
                        <span class="deck-matrix__rollup-seg" data-status="passable"                    data-zero={r.scroll.passable === 0 ? "true" : "false"}><span class="g">P</span>{r.scroll.passable}</span>
                        <span class="deck-matrix__rollup-seg" data-status="non-urgent-could-be-better"  data-zero={r.scroll["non-urgent-could-be-better"] === 0 ? "true" : "false"}><span class="g">C</span>{r.scroll["non-urgent-could-be-better"]}</span>
                        <span class="deck-matrix__rollup-seg" data-status="urgent-redo"                 data-zero={r.scroll["urgent-redo"] === 0 ? "true" : "false"}><span class="g">U</span>{r.scroll["urgent-redo"]}</span>
                        <span class="deck-matrix__rollup-seg" data-status="pending"                     data-zero={r.scroll.pending === 0 ? "true" : "false"}><span class="g">—</span>{r.scroll.pending}</span>
                      </span>
                    </a>

                    {playHref ? (
                      <a
                        class="deck-matrix__surface-row deck-matrix__surface-row--link"
                        href={playHref}
                        title={`Open play deck for ${v.label}`}
                      >
                        <span class="deck-matrix__surface-icon"><PlayIcon size="14px" /></span>
                        <span class="deck-matrix__rollup-pill" aria-label="Play-UI rollup">
                          <span class="deck-matrix__rollup-seg" data-status="perfect"                     data-zero={r.play.perfect === 0 ? "true" : "false"}><span class="g">★</span>{r.play.perfect}</span>
                          <span class="deck-matrix__rollup-seg" data-status="passable"                    data-zero={r.play.passable === 0 ? "true" : "false"}><span class="g">P</span>{r.play.passable}</span>
                          <span class="deck-matrix__rollup-seg" data-status="non-urgent-could-be-better"  data-zero={r.play["non-urgent-could-be-better"] === 0 ? "true" : "false"}><span class="g">C</span>{r.play["non-urgent-could-be-better"]}</span>
                          <span class="deck-matrix__rollup-seg" data-status="urgent-redo"                 data-zero={r.play["urgent-redo"] === 0 ? "true" : "false"}><span class="g">U</span>{r.play["urgent-redo"]}</span>
                          <span class="deck-matrix__rollup-seg" data-status="pending"                     data-zero={r.play.pending === 0 ? "true" : "false"}><span class="g">—</span>{r.play.pending}</span>
                          {r.play["missing-file"] > 0 && (
                            <span class="deck-matrix__rollup-seg" data-kind="missing-file"><span class="g">✕</span>{r.play["missing-file"]}</span>
                          )}
                        </span>
                      </a>
                    ) : (
                      <div
                        class="deck-matrix__surface-row deck-matrix__surface-row--disabled"
                        title="No play deck available — no per-slide Play-UI files exist for this variant yet"
                      >
                        <span class="deck-matrix__surface-icon"><PlayIcon size="14px" /></span>
                        <span class="deck-matrix__rollup-pill" aria-label="Play-UI rollup (no playable slots)">
                          {r.play["missing-file"] > 0 ? (
                            <span class="deck-matrix__rollup-seg" data-kind="missing-file"><span class="g">✕</span>{r.play["missing-file"]}</span>
                          ) : (
                            <span class="deck-matrix__rollup-seg" data-kind="missing-file"><span class="g">—</span>no slots</span>
                          )}
                        </span>
                      </div>
                    )}

                    <div>
                      {r.ready ? (
                        <span class="deck-matrix__ready-badge">Ready</span>
                      ) : (
                        <span class="deck-matrix__ready-badge is-not">Not ready</span>
                      )}
                    </div>
                  </div>
                </th>
              );
            })}
            <th class="deck-matrix__drift-col" scope="col" title="Drift across this row">≠</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <td class="deck-matrix__slot-num">{row.slot}</td>
              <td class="deck-matrix__row-title">{row.title}</td>
              {variants.map((v) => {
                const cell = row.cells[v.slug];
                const isFocused = v.slug === focusVariant;
                return (
                  <td class:list={["deck-matrix__cell", { "is-focused": isFocused }]}>
                    <span class="deck-matrix__cell-inner">
                      <a
                        class="deck-matrix__surface-link"
                        href={cell.scrollHref ?? "#"}
                        data-disabled={cell.scroll.kind === "missing-slot" ? "true" : "false"}
                        title={`Scroll · ${cell.scroll.kind === "rated" ? cell.scroll.status : cell.scroll.kind}`}
                      >
                        <span class="deck-matrix__cell-icon"><ScrollIcon size="14px" /></span>
                        <span
                          class="deck-matrix__chip"
                          data-status={cell.scroll.kind === "rated" ? cell.scroll.status : undefined}
                          data-kind={cell.scroll.kind !== "rated" ? cell.scroll.kind : undefined}
                        >
                          {cell.scroll.kind === "rated"
                            ? STATUS_LABEL[cell.scroll.status]
                            : cell.scroll.kind === "missing-slot"
                            ? "·"
                            : "—"}
                        </span>
                      </a>
                      <span class="deck-matrix__sep">·</span>
                      <a
                        class="deck-matrix__surface-link"
                        href={cell.playHref ?? "#"}
                        data-disabled={cell.play.kind === "missing-slot" || cell.play.kind === "missing-file" ? "true" : "false"}
                        title={`Play · ${cell.play.kind === "rated" ? cell.play.status : cell.play.kind}`}
                      >
                        <span class="deck-matrix__cell-icon"><PlayIcon size="14px" /></span>
                        <span
                          class="deck-matrix__chip"
                          data-status={cell.play.kind === "rated" ? cell.play.status : undefined}
                          data-kind={cell.play.kind !== "rated" ? cell.play.kind : undefined}
                        >
                          {cell.play.kind === "rated"
                            ? STATUS_LABEL[cell.play.status]
                            : cell.play.kind === "missing-slot"
                            ? "·"
                            : cell.play.kind === "missing-file"
                            ? "✕"
                            : "—"}
                        </span>
                      </a>
                    </span>
                  </td>
                );
              })}
              <td
                class="deck-matrix__drift"
                data-drift={row.drift ? "true" : "false"}
                title={row.drift ? "Scroll and Play disagree on at least one variant" : ""}
              >
                {row.drift ? "≠" : ""}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</section>

<style>
  /* Component-scoped palette; consumers can override any --ddd-matrix-* token
     at a wrapping element. Defaults inherit chroma's TOC look. */
  .deck-matrix {
    --ddd-matrix-bg:        var(--ddd-matrix-bg-override, transparent);
    --ddd-matrix-fg:        var(--ddd-matrix-fg-override, currentColor);
    --ddd-matrix-muted:     var(--ddd-matrix-muted-override, color-mix(in srgb, currentColor 55%, transparent));
    --ddd-matrix-line:      var(--ddd-matrix-line-override, color-mix(in srgb, currentColor 12%, transparent));
    --ddd-matrix-panel:     var(--ddd-matrix-panel-override, color-mix(in srgb, currentColor 5%, transparent));
    --ddd-matrix-pill-bg:   var(--ddd-matrix-pill-bg-override, color-mix(in srgb, currentColor 8%, transparent));
    --ddd-matrix-accent:    var(--ddd-matrix-accent-override, #2b7fff);
    --ddd-matrix-urgent:    #ff5e57;
    --ddd-matrix-could:     #ffb84a;
    --ddd-matrix-passable:  #66c0f4;
    --ddd-matrix-perfect:   #4ade80;
    --ddd-matrix-pending:   #6b7280;
    --ddd-matrix-ready:     #4ade80;
    --ddd-matrix-na:        color-mix(in srgb, currentColor 12%, transparent);
    color: var(--ddd-matrix-fg);
    background: var(--ddd-matrix-bg);
  }
  .deck-matrix__head { margin-bottom: 24px; border-bottom: 1px solid var(--ddd-matrix-line); padding-bottom: 16px; }
  .deck-matrix__crumb { color: var(--ddd-matrix-muted); font-size: 13px; }
  .deck-matrix__title { margin: 4px 0 6px; font-size: 22px; font-weight: 600; }
  .deck-matrix__lede { color: var(--ddd-matrix-muted); margin: 0; font-size: 13px; max-width: 70ch; }

  /* Variant filter — chip strip above the matrix. */
  .deck-matrix__variant-filter {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 16px;
    flex-wrap: wrap;
  }
  .deck-matrix__variant-filter-label {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ddd-matrix-muted);
  }
  .deck-matrix__variant-filter-count {
    font-variant-numeric: tabular-nums;
    letter-spacing: 0;
    text-transform: none;
    margin-left: 4px;
    opacity: 0.75;
  }
  .deck-matrix__variant-filter-chips {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .deck-matrix__variant-chip {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    border: 1px solid var(--ddd-matrix-line);
    background: var(--ddd-matrix-pill-bg);
    color: var(--ddd-matrix-muted);
    transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
  }
  .deck-matrix__variant-chip:hover {
    background: var(--ddd-matrix-panel);
    color: var(--ddd-matrix-fg);
  }

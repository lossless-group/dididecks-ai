---
/**
 * @deprecated Since v0.2. Use `<DeckChrome>` directly.
 *
 * Thin shim around `<DeckChrome>` so any external code still importing
 * `PlayChrome` keeps working through the transition. v0.1's heavy dark
 * bottom-bar chrome was replaced by the calmstorm-flavored floating
 * capsule per:
 *   dididecks-ai/context-v/plans/
 *   Restore-Calmstorm-Nav-Elegance-as-Themable-Shell-Primitives.md
 *
 * MIGRATION:
 *   - The shim now expects to be rendered alongside (not wrapping) the
 *     slot content. It emits the floating `<DeckChrome>` only — the
 *     consumer is responsible for the surrounding `[data-play-root]`
 *     wrapper and rendering slot content directly.
 *   - For the v0.1 shape (`<PlayChrome>{children}</PlayChrome>`), keep
 *     using this shim — it still renders children inside a
 *     `[data-play-root]` wrapper so the chrome-hide pattern keeps working.
 *
 * Remove in v0.3.
 */
import DeckChrome from "./DeckChrome.astro";
import "../styles/themes/neutral.css";

interface Props {
  deckSlug?: string;
  variantSlug?: string;
  slot: string;
  totalSlots: number;
  prevHref: string | null;
  nextHref: string | null;
  firstHref: string;
  lastHref: string;
  tocHref: string;
  variantLabel: string;
}

const {
  slot,
  totalSlots,
  variantLabel,
  prevHref,
  nextHref,
  firstHref,
  lastHref,
  tocHref,
} = Astro.props as Props;
---
<div class="ddd-play-shim" data-play-root>
  <main class="ddd-play-shim__stage">
    <slot />
  </main>
  <DeckChrome
    slot={slot}
    totalSlots={totalSlots}
    variantLabel={variantLabel}
    prevHref={prevHref}
    nextHref={nextHref}
    firstHref={firstHref}
    lastHref={lastHref}
    tocHref={tocHref}
  />
</div>

<style>
  .ddd-play-shim {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  .ddd-play-shim__stage {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: auto;
  }
</style>

---
/**
 * /play/[deckSlug]/[variantSlug]/[slot]/ — play runtime.
 *
 * Consumes <DeckOverlay--Play-UI>, which composes:
 *   - DeckChrome      (floating bottom-right capsule, full keyboard contract)
 *   - SlideRankPill   (top-right, in-play classifier — closes A++.2)
 *   - Section wrap    (<section data-slot data-variant>) so SlideRankPill's
 *                     IntersectionObserver picks up the active slot without a
 *                     special play-mode code path.
 *
 * Plans of record:
 *   context-v/plans/Phase-A-Plus-Plus-Play-Fidelity-In-Play-Ranking-and-Variant-URL-Safety.md (A++.2)
 *   context-v/plans/Restore-Calmstorm-Nav-Elegance-as-Themable-Shell-Primitives.md
 *
 * The dynamic-import path is hardcoded to /src/components/slides/** — Vite's
 * import.meta.glob requires a literal string. Phase B can support arbitrary
 * slidesComponentsRoot if needed.
 */
import type { Deck, SlotRef } from "../../../../types/index.js";
import { loadDecksRegistry, loadSlotsRegistry } from "../../../../registry-loader.js";
import DecomposeFirstPlaceholder from "../../../../components/DecomposeFirstPlaceholder.astro";
import SlideCanvas from "../../../../components/SlideCanvas.astro";
import DeckOverlayPlayUI from "../../../../components/DeckOverlay--Play-UI.astro";
import "../../../../styles/themes/neutral.css";

// Globbed lazily; Vite resolves against the consumer's project root at build.
const slideModules = import.meta.glob("/src/components/slides/**/*.astro");

// Path enumeration for static builds. SSR consumers (output:"server" + no
// prerender, e.g. chroma-decks where prerender would defeat the auth gate)
// don't call this — they match by URL pattern and run the frontmatter at
// request time, so the per-request data load below has to stand alone.
export async function getStaticPaths() {
  const opts = globalThis.__dididecksShellOptions;
  if (!opts) {
    throw new Error("@dididecks/shell: options not resolved. Did astro:config:done run?");
  }
  const { DECKS } = await loadDecksRegistry(opts.absolute.decksRegistry);
  const slotsMod = await loadSlotsRegistry(opts.absolute.slotsRegistry);
  const slotsByVariant = slotsMod?.SLOTS ?? {};

  const paths: Array<{
    params: { deckSlug: string; variantSlug: string; slot: string };
  }> = [];
  for (const deck of DECKS as Deck[]) {
    deck.variants.forEach((variant) => {
      const slots = slotsByVariant[variant.slug] ?? [];
      slots.forEach((s) => {
        paths.push({
          params: { deckSlug: deck.slug, variantSlug: variant.slug, slot: s.slot },
        });
      });
    });
  }
  return paths;
}

const { deckSlug, variantSlug, slot } = Astro.params as {
  deckSlug: string;
  variantSlug: string;
  slot: string;
};

// Resolve everything from params + the registry at runtime. Works the same in
// static (prerendered) builds and SSR — Astro.props is unused on purpose, so
// SSR consumers without prerender don't crash on undefined props.
const opts = globalThis.__dididecksShellOptions;
if (!opts) {
  throw new Error("@dididecks/shell: options not resolved. Did astro:config:done run?");
}
const { DECKS } = await loadDecksRegistry(opts.absolute.decksRegistry);
const slotsMod = await loadSlotsRegistry(opts.absolute.slotsRegistry);
const slotsByVariant = slotsMod?.SLOTS ?? {};

const deck = (DECKS as Deck[]).find((d) => d.slug === deckSlug);
if (!deck) {
  return new Response(`Deck not found: ${deckSlug}`, { status: 404 });
}
const variantIdx = deck.variants.findIndex((v) => v.slug === variantSlug);
if (variantIdx === -1) {
  return new Response(`Variant not found: ${variantSlug}`, { status: 404 });
}
const slots: SlotRef[] = slotsByVariant[variantSlug] ?? [];
const slotIdx = slots.findIndex((s) => s.slot === slot);
if (slotIdx === -1) {
  return new Response(`Slot not found: ${slot}`, { status: 404 });
}
const slotEntry = slots[slotIdx];
const slug = slotEntry.slug;
const title = slotEntry.title;
const variantLabel = deck.variants[variantIdx].label;
const deckVariants = deck.variants.map((v) => ({ slug: v.slug, label: v.label }));

const totalSlots = slots.length;
const prevSlot = slotIdx > 0 ? slots[slotIdx - 1] : null;
const nextSlot = slotIdx < totalSlots - 1 ? slots[slotIdx + 1] : null;
const firstSlot = slots[0];
const lastSlot = slots[totalSlots - 1];

const prevHref = prevSlot ? `/play/${deckSlug}/${variantSlug}/${prevSlot.slot}/` : null;
const nextHref = nextSlot ? `/play/${deckSlug}/${variantSlug}/${nextSlot.slot}/` : null;
const firstHref = `/play/${deckSlug}/${variantSlug}/${firstSlot.slot}/`;
const lastHref = `/play/${deckSlug}/${variantSlug}/${lastSlot.slot}/`;
const tocHref = `/toc/${deckSlug}/${variantSlug}/`;
const auditHref = `/toc/${deckSlug}/?variant=${variantSlug}`;

// Variant cycle — siblings of this variant in registry order. Land each
// switch on the same slot number if it exists in the target variant;
// otherwise the variant's slot 01. (Slot existence in the target is
// resolved at runtime by getStaticPaths; we just send the user there.)
const totalVariants = deckVariants.length;
const prevVariantIdx = totalVariants > 1 ? (variantIdx - 1 + totalVariants) % totalVariants : -1;
const nextVariantIdx = totalVariants > 1 ? (variantIdx + 1) % totalVariants : -1;
const prevVariant = prevVariantIdx >= 0 ? deckVariants[prevVariantIdx] : null;
const nextVariant = nextVariantIdx >= 0 ? deckVariants[nextVariantIdx] : null;
const prevVariantHref = prevVariant ? `/play/${deckSlug}/${prevVariant.slug}/${slot}/` : null;
const nextVariantHref = nextVariant ? `/play/${deckSlug}/${nextVariant.slug}/${slot}/` : null;
const variantCounter = totalVariants > 1 ? `${variantIdx + 1}/${totalVariants}` : undefined;
// All variants for the bottom-bar "Switch Variant ▾" menu, in registry
// order, current included (marked + non-clickable). The component renders
// the menu when this list has more than one entry.
const allVariants = deckVariants.map((v) => ({
  slug: v.slug,
  label: v.label,
  href: v.slug === variantSlug ? null : `/play/${deckSlug}/${v.slug}/${slot}/`,
  isCurrent: v.slug === variantSlug,
}));

// Audience intent — URL-param toggle per the redesign plan. Default "workflow"
// preserves the operator/VC-firm view that's been the only mode shipped so
// far. Pass ?intent=presentation to render the end-user view.
const intentParam = Astro.url.searchParams.get("intent");
const intent: "workflow" | "presentation" =
  intentParam === "presentation" ? "presentation" : "workflow";

const globKey = `/src/components/slides/${variantSlug}/${slot}-${slug}.astro`;
type SlideLoader = () => Promise<{ default: unknown }>;
const slideLoader = slideModules[globKey] as SlideLoader | undefined;
const Slide = slideLoader ? ((await slideLoader()).default as unknown) : null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · {variantLabel} · play</title>
    <meta name="robots" content="noindex,nofollow" />
  </head>
  <body class="ddd-play-body">
    <DeckOverlayPlayUI
      deckSlug={deckSlug}
      variantSlug={variantSlug}
      slot={slot}
      slotTitle={title}
      totalSlots={totalSlots}
      variantLabel={variantLabel}
      variantCounter={variantCounter}
      prevHref={prevHref}
      nextHref={nextHref}
      firstHref={firstHref}
      lastHref={lastHref}
      tocHref={tocHref}
      prevVariantHref={prevVariantHref}
      nextVariantHref={nextVariantHref}
      allVariants={allVariants}
      auditHref={auditHref}
      intent={intent}
    >
      {/* Slides self-wrap in their own SlideCanvas. The empty-slot fallback
          wraps the placeholder manually since it doesn't bring its own. */}
      {Slide ? (
        <Slide />
      ) : (
        <SlideCanvas>
          <DecomposeFirstPlaceholder
            deckSlug={deckSlug}
            variantSlug={variantSlug}
            slot={slot}
            slug={slug}
            title={title}
          />
        </SlideCanvas>
      )}
    </DeckOverlayPlayUI>

    <style is:global>
      html, body { margin: 0; padding: 0; }
      .ddd-play-body {
        background: var(--ddd-play-stage-bg, #0a0f1a);
        min-height: 100vh;
        min-height: 100dvh;
        overflow: hidden;
      }

      /* ── Canvas letterbox (load-bearing) ────────────────────────────
         The overlay's .ddd-overlay__stage centers a single flex child.
         The slide-canvas inside has aspect-ratio:16/9 + width:100%, which
         would overflow the viewport vertically when the viewport is wide.
         This rule sizes the canvas to the largest 16:9 box that fits the
         current viewport. With DeckChrome as a floating capsule (no top
         or bottom bars) we have the full viewport to work with. */
      .ddd-play-body .ddd-overlay__stage > .slide-canvas {
        width: min(100vw, calc(100vh * 16 / 9));
        max-height: 100vh;
        max-height: 100dvh;
        box-shadow: var(--ddd-play-canvas-shadow, 0 12px 48px rgb(0 0 0 / 0.4));
        border-radius: var(--ddd-play-canvas-radius, 4px);
      }

      /* Chrome-off mode (C / F) — DeckChrome's keypress flips
         [data-chrome-hidden] on the overlay root. Drop the canvas shadow
         and rounding for a cleaner fullscreen feel. */
      .ddd-overlay--play[data-chrome-hidden="true"] .ddd-overlay__stage > .slide-canvas {
        border-radius: 0;
        box-shadow: none;
      }
    </style>
  </body>
</html>

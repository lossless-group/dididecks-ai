---
/**
 * /play/[deckSlug]/[variantSlug]/[slot]/ — minimum-viable play runtime.
 *
 * Faithful port of calmstorm-decks' /play/section/[slot].astro pattern:
 *   - body is `overflow: hidden`, full-viewport (100dvh)
 *   - fixed top + bottom chrome bars (NOT a floating capsule — that's
 *     the scroll-route surface, lives in DeckChrome.astro for later)
 *   - center-stage with letterbox-constrained canvas:
 *       width: min(100%, calc((100vh - 7rem) * 16 / 9))
 *       max-height: calc(100vh - 7rem)
 *     This is the load-bearing CSS that prevents the
 *     `width:100% + aspect-ratio:16/9` canvas from blowing out the
 *     viewport. Calmstorm tested; we copy it.
 *   - Chrome-off mode (`C` / `F`) neutralizes the canvas's own
 *     aspect-ratio rule and locks both axes to the largest 16:9 box
 *     that fits the viewport, symmetric letterbox on the leftover axis.
 *
 * Calmstorm's hardcoded #0a0f1a dark theme is parameterized via
 * --ddd-play-*-* and --ddd-chrome-*-* CSS custom properties. Consumers
 * override at any wrapping element (commonly `:root` or scoped via
 * `:root[data-deck-skin="..."]`); the defaults in
 * styles/themes/neutral.css reproduce calmstorm's look.
 *
 * Keyboard contract: ← / → / Space / PageUp / PageDown / Home / End
 * walk slots; F fullscreens; C toggles chrome (body[data-chrome=off]);
 * T jumps to TOC; Esc restores chrome + exits fullscreen.
 *
 * The dynamic-import path is hardcoded to /src/components/slides/** for
 * v0 — Vite's import.meta.glob requires a literal string. Phase B can
 * support arbitrary slidesComponentsRoot if needed.
 *
 * Plan of record:
 *   dididecks-ai/context-v/plans/
 *   Restore-Calmstorm-Nav-Elegance-as-Themable-Shell-Primitives.md
 */
import type { Deck, SlotRef } from "../../../../types/index.js";
import { loadDecksRegistry, loadSlotsRegistry } from "../../../../registry-loader.js";
import DecomposeFirstPlaceholder from "../../../../components/DecomposeFirstPlaceholder.astro";
import SlideCanvas from "../../../../components/SlideCanvas.astro";
import "../../../../styles/themes/neutral.css";

// Globbed lazily; Vite resolves against the consumer's project root at build.
const slideModules = import.meta.glob("/src/components/slides/**/*.astro");

export async function getStaticPaths() {
  const opts = globalThis.__dididecksShellOptions;
  if (!opts) {
    throw new Error("@dididecks/shell: options not resolved. Did astro:config:done run?");
  }
  const { DECKS } = await loadDecksRegistry(opts.absolute.decksRegistry);
  const slotsMod = await loadSlotsRegistry(opts.absolute.slotsRegistry);
  const slotsByVariant = slotsMod?.SLOTS ?? {};

  const paths: Array<{
    params: { deckSlug: string; variantSlug: string; slot: string };
    props: { slug: string; title: string; slotIdx: number; slots: SlotRef[]; variantLabel: string };
  }> = [];

  for (const deck of DECKS as Deck[]) {
    for (const variant of deck.variants) {
      const slots = slotsByVariant[variant.slug] ?? [];
      slots.forEach((slot, idx) => {
        paths.push({
          params: { deckSlug: deck.slug, variantSlug: variant.slug, slot: slot.slot },
          props: {
            slug: slot.slug,
            title: slot.title,
            slotIdx: idx,
            slots,
            variantLabel: variant.label,
          },
        });
      });
    }
  }
  return paths;
}

const { deckSlug, variantSlug, slot } = Astro.params as {
  deckSlug: string;
  variantSlug: string;
  slot: string;
};
const { slug, title, slotIdx, slots, variantLabel } = Astro.props as {
  slug: string;
  title: string;
  slotIdx: number;
  slots: SlotRef[];
  variantLabel: string;
};

const totalSlots = slots.length;
const prevSlot = slotIdx > 0 ? slots[slotIdx - 1] : null;
const nextSlot = slotIdx < totalSlots - 1 ? slots[slotIdx + 1] : null;
const firstSlot = slots[0];
const lastSlot = slots[totalSlots - 1];

const prevHref = prevSlot ? `/play/${deckSlug}/${variantSlug}/${prevSlot.slot}/` : null;
const nextHref = nextSlot ? `/play/${deckSlug}/${variantSlug}/${nextSlot.slot}/` : null;
const firstHref = `/play/${deckSlug}/${variantSlug}/${firstSlot.slot}/`;
const lastHref = `/play/${deckSlug}/${variantSlug}/${lastSlot.slot}/`;
const tocHref = `/toc/${deckSlug}/${variantSlug}/`;

const slotPadded = String(slot).padStart(2, "0");
const totalPadded = String(totalSlots).padStart(2, "0");

const globKey = `/src/components/slides/${variantSlug}/${slot}-${slug}.astro`;
type SlideLoader = () => Promise<{ default: unknown }>;
const slideLoader = slideModules[globKey] as SlideLoader | undefined;
const Slide = slideLoader ? ((await slideLoader()).default as unknown) : null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · {variantLabel} · play</title>
    <meta name="robots" content="noindex,nofollow" />
  </head>
  <body class="ddd-play-body" data-chrome="on">

    <header class="ddd-play-chrome ddd-play-chrome--top">
      <a
        href={tocHref}
        class="ddd-play-exit"
        aria-label="Exit to table of contents"
        title="Exit to TOC (T)"
      >
        <span aria-hidden="true">✕</span>
      </a>
      <span class="ddd-play-brand">
        {title}
      </span>
      <span class="ddd-play-mid">
        <span class="ddd-play-variant">
          <span class="ddd-play-variant-label">Variant</span>
          <span class="ddd-play-variant-name">{variantLabel}</span>
        </span>
      </span>
      <span class="ddd-play-counter">
        <span data-counter-slot>{slotPadded}</span> / {totalPadded}
      </span>
    </header>

    <main class="ddd-play-stage">
      <article class="ddd-play-slide" aria-hidden="false">
        {/* Slides self-wrap in their own SlideCanvas. The route does NOT
            wrap — that caused double-canvas drift. For empty-slot fallback
            we wrap the placeholder manually since it doesn't bring its own. */}
        {Slide ? (
          <Slide />
        ) : (
          <SlideCanvas>
            <DecomposeFirstPlaceholder
              deckSlug={deckSlug}
              variantSlug={variantSlug}
              slot={slot}
              slug={slug}
              title={title}
            />
          </SlideCanvas>
        )}
      </article>
    </main>

    <nav class="ddd-play-chrome ddd-play-chrome--bottom">
      <span class="ddd-play-section-nav">
        {prevHref ? (
          <a href={prevHref} class="ddd-play-nav-link" data-nav="prev">‹ Prev</a>
        ) : (
          <span class="ddd-play-nav-link is-disabled" aria-disabled="true">‹ Prev</span>
        )}
      </span>

      <span class="ddd-play-hint">
        ← → slots · F fullscreen · C toggle chrome · T toc
      </span>

      <span class="ddd-play-section-nav">
        <a href={tocHref} class="ddd-play-nav-link" data-nav="toc">TOC</a>
        {nextHref ? (
          <a href={nextHref} class="ddd-play-nav-link" data-nav="next">Next ›</a>
        ) : (
          <span class="ddd-play-nav-link is-disabled" aria-disabled="true">Next ›</span>
        )}
      </span>
    </nav>

    <style is:global>
      html, body { margin: 0; padding: 0; }
      .ddd-play-body {
        background: var(--ddd-play-stage-bg, #0a0f1a);
        min-height: 100vh;
        min-height: 100dvh;
        overflow: hidden;
      }
    </style>

    <style>
      /* ── Chrome bars (fixed top + bottom) ─────────────────────────── */

      .ddd-play-chrome {
        position: fixed;
        left: 0;
        right: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.65rem 1rem;
        font-family: var(--ddd-chrome-font, ui-sans-serif, system-ui, sans-serif);
        font-size: 0.7rem;
        color: var(--ddd-play-chrome-fg, rgb(255 255 255 / 0.65));
        background: var(--ddd-play-chrome-bg, rgb(10 15 26 / 0.85));
        backdrop-filter: var(--ddd-play-chrome-backdrop, blur(6px));
        -webkit-backdrop-filter: var(--ddd-play-chrome-backdrop, blur(6px));
        transition: opacity 200ms ease, transform 200ms ease;
      }
      .ddd-play-chrome--top {
        top: 0;
        border-bottom: 1px solid var(--ddd-play-chrome-border, rgb(255 255 255 / 0.08));
      }
      .ddd-play-chrome--bottom {
        bottom: 0;
        border-top: 1px solid var(--ddd-play-chrome-border, rgb(255 255 255 / 0.08));
        justify-content: space-between;
      }

      /* ── Top-chrome contents ──────────────────────────────────────── */

      .ddd-play-brand {
        font-weight: 600;
        letter-spacing: 0.04em;
        color: var(--ddd-play-chrome-fg-strong, white);
        flex-shrink: 0;
        max-width: 40%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .ddd-play-exit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.6rem;
        height: 1.6rem;
        margin-right: 0.75rem;
        border: 1px solid var(--ddd-play-link-border, rgb(255 255 255 / 0.25));
        border-radius: 4px;
        color: var(--ddd-play-chrome-fg, rgb(255 255 255 / 0.75));
        font-size: 0.95rem;
        line-height: 1;
        text-decoration: none;
        flex-shrink: 0;
        transition:
          color 0.15s ease,
          border-color 0.15s ease,
          background-color 0.15s ease,
          box-shadow 0.15s ease,
          transform 0.1s ease;
      }
      .ddd-play-exit:hover {
        color: var(--ddd-play-chrome-fg-strong, white);
        border-color: var(--ddd-play-link-border-hover, rgb(255 255 255 / 0.7));
        background-color: var(--ddd-play-link-bg-hover, rgb(255 255 255 / 0.06));
        box-shadow: 0 0 14px rgb(255 255 255 / 0.25);
      }
      .ddd-play-exit:active { transform: scale(0.94); }
      .ddd-play-exit:focus-visible {
        outline: 2px solid rgb(125 211 252 / 0.7);
        outline-offset: 2px;
      }

      .ddd-play-mid {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex: 1;
        justify-content: center;
        flex-wrap: wrap;
      }
      .ddd-play-variant {
        display: inline-flex;
        align-items: baseline;
        gap: 0.5rem;
        font-size: 0.72rem;
        color: var(--ddd-play-chrome-fg-strong, rgb(255 255 255 / 0.85));
      }
      .ddd-play-variant-label {
        font-size: 0.6rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--ddd-play-chrome-fg-muted, rgb(255 255 255 / 0.45));
      }
      .ddd-play-variant-name {
        font-family: var(--ddd-chrome-font, ui-sans-serif, system-ui, sans-serif);
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
      }

      .ddd-play-counter {
        font-variant-numeric: tabular-nums;
        letter-spacing: 0.08em;
        flex-shrink: 0;
      }

      /* ── Bottom-chrome contents ───────────────────────────────────── */

      .ddd-play-hint {
        margin: 0 auto;
        font-size: 0.62rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        opacity: 0.55;
      }
      .ddd-play-section-nav {
        display: flex;
        gap: 0.6rem;
        flex-shrink: 0;
      }
      .ddd-play-nav-link {
        color: var(--ddd-play-chrome-fg-strong, rgb(255 255 255 / 0.85));
        text-decoration: none;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        padding: 0.35rem 0.85rem;
        background: var(--ddd-play-link-bg, transparent);
        border: 1px solid var(--ddd-play-link-border, rgb(255 255 255 / 0.2));
        border-radius: 3px;
        transition: background 150ms ease, border-color 150ms ease;
      }
      .ddd-play-nav-link:hover {
        background: var(--ddd-play-link-bg-hover, rgb(255 255 255 / 0.08));
        border-color: var(--ddd-play-link-border-hover, rgb(255 255 255 / 0.5));
      }
      .ddd-play-nav-link.is-disabled {
        opacity: 0.3;
        pointer-events: none;
      }

      /* ── Chrome-off mode (C key or F fullscreen) ──────────────────── */

      .ddd-play-body[data-chrome="off"] .ddd-play-chrome--top {
        opacity: 0;
        transform: translateY(-100%);
        pointer-events: none;
      }
      .ddd-play-body[data-chrome="off"] .ddd-play-chrome--bottom {
        opacity: 0;
        transform: translateY(100%);
        pointer-events: none;
      }

      /* ── Stage + slide + canvas (the load-bearing letterbox CSS) ──── */

      .ddd-play-stage {
        position: relative;
        width: 100vw;
        height: 100vh;
        height: 100dvh;
        display: grid;
        place-items: center;
      }

      .ddd-play-slide {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        padding: 3.5rem 2rem;
      }

      /* Direct-child only — slides may self-wrap in their own
         SlideCanvas (per the scroll-ported-slides refactor plan), so
         the descendant combinator would double-apply this letterbox
         sizing to the inner canvas and break the stage transform. */
      .ddd-play-slide > :global(.slide-canvas) {
        width: min(100%, calc((100vh - 7rem) * 16 / 9));
        max-height: calc(100vh - 7rem);
        max-height: calc(100dvh - 7rem);
        box-shadow: var(--ddd-play-canvas-shadow, 0 12px 48px rgb(0 0 0 / 0.4));
        border-radius: var(--ddd-play-canvas-radius, 4px);
      }

      /* Chrome-off mode neutralizes the canvas's own aspect-ratio rule
         and locks both axes to the largest 16:9 box that fits the
         viewport, with symmetric letterbox on the leftover axis.
         Direct-child only — same reason as the chrome-on rule above. */
      .ddd-play-body[data-chrome="off"] .ddd-play-slide { padding: 0; }
      .ddd-play-body[data-chrome="off"] .ddd-play-slide > :global(.slide-canvas) {
        width:  min(100vw, calc(100vh * 16 / 9));
        height: min(100vh, calc(100vw * 9 / 16));
        max-width: 100vw;
        max-height: 100vh;
        max-height: 100dvh;
        aspect-ratio: auto;
        border-radius: 0;
        box-shadow: none;
      }
    </style>

    <script
      is:inline
      data-prev={prevHref ?? ""}
      data-next={nextHref ?? ""}
      data-first={firstHref}
      data-last={lastHref}
      data-toc={tocHref}
    >
      (() => {
        const cfg = document.currentScript;
        if (!cfg) return;
        const prev = cfg.getAttribute("data-prev") || null;
        const next = cfg.getAttribute("data-next") || null;
        const first = cfg.getAttribute("data-first");
        const last = cfg.getAttribute("data-last");
        const toc = cfg.getAttribute("data-toc");
        const body = document.body;

        function go(href) {
          if (href && href !== "#") window.location.href = href;
        }
        function toggleChrome() {
          body.dataset.chrome = body.dataset.chrome === "off" ? "on" : "off";
        }
        function toggleFullscreen() {
          if (!document.fullscreenElement) {
            document.documentElement.requestFullscreen?.().catch(() => {});
          } else {
            document.exitFullscreen?.();
          }
        }

        document.addEventListener("keydown", (e) => {
          const t = e.target;
          if (t instanceof HTMLElement) {
            const tag = t.tagName;
            if (tag === "INPUT" || tag === "TEXTAREA" || t.isContentEditable) return;
          }
          switch (e.key) {
            case "ArrowRight":
            case "PageDown":
              e.preventDefault(); go(next); break;
            case " ":
              e.preventDefault();
              if (e.shiftKey) go(prev); else go(next);
              break;
            case "ArrowLeft":
            case "PageUp":
              e.preventDefault(); go(prev); break;
            case "Home":
              e.preventDefault(); go(first); break;
            case "End":
              e.preventDefault(); go(last); break;
            case "f":
            case "F":
              e.preventDefault(); toggleFullscreen(); break;
            case "c":
            case "C":
              e.preventDefault(); toggleChrome(); break;
            case "t":
            case "T":
              e.preventDefault(); go(toc); break;
            case "Escape":
              if (document.fullscreenElement) document.exitFullscreen?.();
              body.dataset.chrome = "on";
              break;
          }
        });
      })();
    </script>
  </body>
</html>

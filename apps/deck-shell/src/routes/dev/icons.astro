---
/**
 * /dev/icons — recurring design-review surface.
 *
 * Originally a one-off Phase 4 review page for the dual-surface icon pair
 * (scroll glyph + play glyph). The founder picked Pair B "Frameless glyphs"
 * on 2026-05-17; it is now the canonical `ScrollIcon` + `PlayIcon`.
 *
 * The route is kept as a **pattern** rather than removed:
 *   - "Canonical" section renders the chosen pair at multiple sizes and on
 *     multiple backgrounds — quick regression check after any icon edit.
 *   - "Alternates (design history)" section renders the unchosen pairs from
 *     `components/icons/alternates/` so the decision context remains legible
 *     to anyone reading the codebase cold.
 *
 * Future design reviews — for any icon family, button variant, chip style,
 * or other small visual primitive that benefits from "see all candidates
 * side-by-side at multiple sizes / surfaces" — can extend this route with
 * additional sections. The composed-cell demo strip below each candidate is
 * the load-bearing test: how does the candidate look in the actual UI
 * context it will live in, not in isolation.
 *
 * Related discipline:
 *   - `maintain-design-md` skill — DESIGN.md as the documented contract
 *   - `context-v/sitemap/` — per-component mini-specs (sibling artifact)
 *
 * Plan of record:
 *   context-v/plans/Redesign-TOC-as-Deck-Level-Dual-Surface-Review-Matrix.md (§D, Phase 4)
 */
import ScrollIcon from "../../components/icons/ScrollIcon.astro";
import PlayIcon from "../../components/icons/PlayIcon.astro";
import ScrollIconA from "../../components/icons/alternates/ScrollIcon-A.astro";
import PlayIconA from "../../components/icons/alternates/PlayIcon-A.astro";
import ScrollIconC from "../../components/icons/alternates/ScrollIcon-C.astro";
import PlayIconC from "../../components/icons/alternates/PlayIcon-C.astro";

const sizes = [16, 24, 32, 48];
const alternates = [
  {
    id: "A",
    label: "Surface-shaped frames",
    notes:
      "Portrait scroll frame + landscape play frame — the aspect ratio of each frame literally encodes the surface it represents (long page vs. 16:9 slide). Stroke-only; reads as outline.",
    Scroll: ScrollIconA,
    Play: PlayIconA,
  },
  {
    id: "C",
    label: "Filled capsules",
    notes:
      "Heavier visual presence. Scroll = mouse-wheel-shaped capsule with a punched wheel notch. Play = filled circle with punched-out ▶. Even-odd fill means the cutouts are transparent on any background.",
    Scroll: ScrollIconC,
    Play: PlayIconC,
  },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Icon review · @dididecks/shell</title>
    <meta name="robots" content="noindex,nofollow" />
    <style>
      :root {
        color-scheme: light dark;
        --fg: #0f172a;
        --fg-muted: #475569;
        --bg: #ffffff;
        --panel: #f8fafc;
        --border: rgb(15 23 42 / 0.08);
        --accent: #f05100;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --fg: #e2e8f0;
          --fg-muted: #94a3b8;
          --bg: #0b0f17;
          --panel: #11171f;
          --border: rgb(226 232 240 / 0.08);
        }
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.5;
      }
      .wrap { max-width: 1100px; margin: 0 auto; padding: 4rem 2rem 8rem; }
      h1 { font-size: 1.75rem; margin: 0 0 0.5rem; letter-spacing: -0.01em; }
      h2 {
        font-size: 0.7rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--fg-muted);
        margin: 3rem 0 1.25rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
      }
      .eyebrow {
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--fg-muted);
        margin-bottom: 0.5rem;
      }
      .lede { max-width: 60ch; color: var(--fg-muted); margin: 0 0 2rem; }
      .canonical-tag {
        display: inline-block;
        background: rgb(74 222 128 / 0.15);
        color: #4ade80;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        padding: 0.2rem 0.55rem;
        border-radius: 3px;
        margin-right: 0.55rem;
      }
      .archived-tag {
        display: inline-block;
        background: rgb(148 163 184 / 0.15);
        color: var(--fg-muted);
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        padding: 0.2rem 0.55rem;
        border-radius: 3px;
        margin-right: 0.55rem;
      }
      .pair {
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.75rem;
        margin-bottom: 1.5rem;
        background: var(--panel);
      }
      .pair.is-archived { opacity: 0.65; }
      .pair-head {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 0.4rem;
      }
      .pair-id { font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); font-weight: 700; }
      .pair-label { font-size: 1.1rem; font-weight: 600; }
      .pair-notes { color: var(--fg-muted); margin: 0 0 1.5rem; max-width: 70ch; font-size: 0.92rem; }
      .swatches { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
      .swatch { border-radius: 8px; padding: 1rem; display: flex; flex-direction: column; align-items: center; gap: 0.65rem; }
      .swatch--light { background: #f5f5f5; color: #0f172a; }
      .swatch--dark { background: #0a0f1a; color: #e6e9ee; }
      .swatch--brand { background: #f05100; color: #fffaf2; }
      .swatch-row { display: flex; align-items: flex-end; gap: 1.25rem; }
      .icon-pair { display: inline-flex; align-items: center; gap: 0.4rem; line-height: 1; }
      .swatch-size-label { font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.6; }
      .composed-row { display: flex; gap: 1rem; margin-top: 1.25rem; flex-wrap: wrap; }
      .compose-cell {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.25rem 0.45rem;
        border: 1px solid rgb(127 127 127 / 0.3);
        border-radius: 4px;
        font-size: 0.85rem;
      }
      .rank-chip {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.1rem 0.45rem;
        border-radius: 3px;
        background: rgb(74 222 128 / 0.85);
        color: #06210c;
      }
      .rank-chip--pending {
        background: transparent;
        border: 1px dashed currentColor;
        opacity: 0.4;
      }
      .nb { font-size: 0.78rem; color: var(--fg-muted); margin-top: 2rem; line-height: 1.6; max-width: 70ch; }
      .nb code {
        background: var(--panel);
        padding: 0.1rem 0.3rem;
        border-radius: 3px;
        font-size: 0.85em;
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <div class="eyebrow">@dididecks/shell · design review</div>
      <h1>Dual-surface icon pair</h1>
      <p class="lede">
        Scroll-surface and Play-surface glyphs, paired for the deck-level TOC
        matrix. The canonical pair below renders next to a rating chip in every
        matrix cell. Alternate pairs are preserved as design history.
      </p>

      <h2>Canonical</h2>
      <section class="pair">
        <div class="pair-head">
          <span class="canonical-tag">Picked 2026-05-17</span>
          <span class="pair-label">Frameless glyphs</span>
        </div>
        <p class="pair-notes">
          No frame. Scroll = three content lines + chevron pointing down. Play =
          standalone ▶ triangle. Most minimal; loudest at 16px because no internal
          detail competes with the silhouette.
        </p>

        <div class="swatches">
          <div class="swatch swatch--light">
            <div class="swatch-row">
              {sizes.map((px) => (
                <div style="display:flex; flex-direction:column; align-items:center; gap:0.35rem;">
                  <span class="icon-pair">
                    <ScrollIcon size={`${px}px`} />
                    <PlayIcon size={`${px}px`} />
                  </span>
                  <span class="swatch-size-label">{px}px</span>
                </div>
              ))}
            </div>
          </div>
          <div class="swatch swatch--dark">
            <div class="swatch-row">
              {sizes.map((px) => (
                <div style="display:flex; flex-direction:column; align-items:center; gap:0.35rem;">
                  <span class="icon-pair">
                    <ScrollIcon size={`${px}px`} />
                    <PlayIcon size={`${px}px`} />
                  </span>
                  <span class="swatch-size-label">{px}px</span>
                </div>
              ))}
            </div>
          </div>
          <div class="swatch swatch--brand">
            <div class="swatch-row">
              {sizes.map((px) => (
                <div style="display:flex; flex-direction:column; align-items:center; gap:0.35rem;">
                  <span class="icon-pair">
                    <ScrollIcon size={`${px}px`} />
                    <PlayIcon size={`${px}px`} />
                  </span>
                  <span class="swatch-size-label">{px}px</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="composed-row">
          <div class="compose-cell" title="Cell: scroll passable + play passable (no drift)">
            <span class="icon-pair" style="font-size: 14px;"><ScrollIcon size="14px" /></span>
            <span class="rank-chip">P</span>
            <span style="opacity:0.3;">·</span>
            <span class="icon-pair" style="font-size: 14px;"><PlayIcon size="14px" /></span>
            <span class="rank-chip" style="background: rgb(102 192 244 / 0.85); color: #0b1a26;">P</span>
          </div>
          <div class="compose-cell" title="Drift: scroll ★ vs play urgent-redo">
            <span class="icon-pair" style="font-size: 14px;"><ScrollIcon size="14px" /></span>
            <span class="rank-chip" style="background: rgb(74 222 128 / 0.85); color: #06210c;">★</span>
            <span style="opacity:0.3;">·</span>
            <span class="icon-pair" style="font-size: 14px;"><PlayIcon size="14px" /></span>
            <span class="rank-chip" style="background: rgb(255 107 107 / 0.85); color: #2b0606;">U</span>
          </div>
          <div class="compose-cell" title="Pending play: per-slide file missing">
            <span class="icon-pair" style="font-size: 14px;"><ScrollIcon size="14px" /></span>
            <span class="rank-chip">P</span>
            <span style="opacity:0.3;">·</span>
            <span class="icon-pair" style="font-size: 14px; opacity: 0.35;"><PlayIcon size="14px" /></span>
            <span class="rank-chip rank-chip--pending">—</span>
          </div>
        </div>
      </section>

      <h2>Alternates · design history</h2>
      {alternates.map(({ id, label, notes, Scroll, Play }) => (
        <section class="pair is-archived">
          <div class="pair-head">
            <span class="archived-tag">Not chosen</span>
            <span class="pair-id">Pair {id}</span>
            <span class="pair-label">{label}</span>
          </div>
          <p class="pair-notes">{notes}</p>

          <div class="swatches">
            <div class="swatch swatch--light">
              <div class="swatch-row">
                {sizes.map((px) => (
                  <div style="display:flex; flex-direction:column; align-items:center; gap:0.35rem;">
                    <span class="icon-pair">
                      <Scroll size={`${px}px`} />
                      <Play size={`${px}px`} />
                    </span>
                    <span class="swatch-size-label">{px}px</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="swatch swatch--dark">
              <div class="swatch-row">
                {sizes.map((px) => (
                  <div style="display:flex; flex-direction:column; align-items:center; gap:0.35rem;">
                    <span class="icon-pair">
                      <Scroll size={`${px}px`} />
                      <Play size={`${px}px`} />
                    </span>
                    <span class="swatch-size-label">{px}px</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="swatch swatch--brand">
              <div class="swatch-row">
                {sizes.map((px) => (
                  <div style="display:flex; flex-direction:column; align-items:center; gap:0.35rem;">
                    <span class="icon-pair">
                      <Scroll size={`${px}px`} />
                      <Play size={`${px}px`} />
                    </span>
                    <span class="swatch-size-label">{px}px</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>
      ))}

      <p class="nb">
        <strong>About this route.</strong> <code>/dev/icons</code> is a recurring
        <em>design-review surface</em> kept after the original Phase 4 review.
        The pattern — render every candidate at multiple sizes / on multiple
        backgrounds / inside its real composed context — generalizes to any
        small visual primitive. Extend this file with new sections for future
        icon families, chip variants, or badge styles rather than spawning a
        new route per review. See <code>maintain-design-md</code> skill for the
        sibling discipline that documents <em>chosen</em> design tokens; this
        route is the workbench where they get chosen.
      </p>
    </main>
  </body>
</html>

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "noEmit": true,
    "types": ["astro/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.astro"],
  "exclude": ["node_modules", ".test-host"]
}

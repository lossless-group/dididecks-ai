{
  "name": "@dididecks/shell",
  "version": "0.0.1",
  "description": "Astro integration that wraps a client-site deck workspace with shared chrome — TOC + slide-ranking UI in v0.1, lifted calmstorm primitives + /play runtime in later releases.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./routes/*": "./src/routes/*",
    "./components/*": "./src/components/*",
    "./runtime/*": "./src/runtime/*",
    "./types": "./src/types/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "astro": "^6.0.0"
  },
  "devDependencies": {
    "astro": "^6.1.7",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lossless-group/dididecks-ai.git",
    "directory": "apps/deck-shell"
  },
  "license": "UNLICENSED",
  "keywords": [
    "astro-integration",
    "astro-component",
    "dididecks",
    "slide-decks-as-code"
  ]
}
